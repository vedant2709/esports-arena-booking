# Copy this file to ".env" and fill in real values.
# ".env" is gitignored and must NEVER be committed.

NODE_ENV=development
# macOS note: port 5000 is used by AirPlay Receiver, so we default to 5001 locally.
PORT=5001

# Allowed browser origin(s) for CORS, comma-separated. e.g. http://localhost:5173
CLIENT_ORIGIN=

# Local dev: mongodb://localhost:27017/esports-arena
# Production: your MongoDB Atlas connection string
MONGODB_URI=

# Local dev: redis://localhost:6379   |   Production: your hosted Redis URL
REDIS_URL=

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Razorpay test keys (key_id is public, key_secret is server-only)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Owner account seeded via node src/seed/seedAdmin.js (no public admin signup)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend transactional email (resend.com)
RESEND_API_KEY=
FROM_EMAIL=E-Sports Arena <onboarding@resend.dev>
# Optional, testing only: route all confirmation emails to one inbox
TEST_EMAIL_OVERRIDE=
